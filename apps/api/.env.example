# dev 环境（本地开发，连远程数据库）
DATABASE_URL=postgresql+asyncpg://username:password@remote-host:5432/your-database

# Clerk Webhook 签名密钥（从 Clerk Dashboard -> Webhooks -> Signing Secret 获取）
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxx

# prod 环境请创建 .env.prod 文件，启动时设置 ENV=prod
# ENV=prod
# DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/your-database
