# dev 环境（本地开发，连远程数据库）
DATABASE_URL=postgresql+asyncpg://username:password@remote-host:5432/your-database

# Clerk Webhook 签名密钥（从 Clerk Dashboard -> Webhooks -> Signing Secret 获取）
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxx

# Clerk JWKS URL（格式：https://<your-clerk-domain>/.well-known/jwks.json）
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json

# prod 环境请创建 .env.prod 文件，启动时设置 ENV=prod
# ENV=prod
# DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/your-database

# OpenRouter API 密钥（从 OpenRouter Dashboard -> API Keys 获取）
OPENROUTER_API_KEY=sk-or-v1-xxxx

# Resend 邮件推送（从 Resend Dashboard -> API Keys 获取）
RESEND_API_KEY=re_xxxx
EMAIL_FROM=AlphaDesk <recommendations@yourdomain.com>

# JQData 数据源（聚宽）— 账号为注册手机号，密码为聚宽官网登录密码
# 申请试用：https://www.joinquant.com/help/api/doc?name=logon&id=9822
JQDATA_USERNAME=13800138000
JQDATA_PASSWORD=your_jqdata_password

# Tushare 数据源 — 注册后从个人中心获取 Token
# 申请地址：https://tushare.pro/register
TUSHARE_TOKEN=your_tushare_token